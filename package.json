{
  "name": "pump-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:web": "npm run dev --workspace @pump/web",
    "dev:api": "npm run dev --workspace @pump/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspace @pump/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
